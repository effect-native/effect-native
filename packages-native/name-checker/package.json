{
  "name": "@effect-native/name-checker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Check domain and npm package name availability with AI suggestions",
  "bin": {
    "name-checker": "./src/cli.ts"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts"
  },
  "scripts": {
    "check": "echo 'nothing to check'",
    "start": "tsx src/cli.ts"
  },
  "dependencies": {
    "@effect-native/fetch-hooks": "workspace:*",
    "@effect-native/openrouter": "workspace:*"
  },
  "devDependencies": {
    "effect": "latest",
    "tsx": "latest"
  }
}
