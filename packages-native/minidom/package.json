{
  "name": "@effect-native/minidom",
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "description": "Capability-driven MiniDom abstractions for Effect Native backends.",
  "homepage": "https://github.com/effect-native/effect-native",
  "repository": {
    "type": "git",
    "url": "https://github.com/effect-native/effect-native.git",
    "directory": "packages-native/minidom"
  },
  "bugs": {
    "url": "https://github.com/effect-native/effect-native/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "directory": "dist",
    "linkDirectory": false
  },
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./core/*": "./src/core/*.ts",
    "./schema/*": "./src/schema/*.ts",
    "./events/*": "./src/events/*.ts",
    "./composite/*": "./src/composite/*.ts",
    "./host/*": "./src/host/*.ts",
    "./adapters/*": "./src/adapters/*.ts",
    "./internal/*": null
  },
  "scripts": {
    "codegen": "echo '@effect-native/minidom: no codegen'",
    "build": "pnpm build-esm && pnpm build-annotate && pnpm build-cjs && build-utils pack-v3",
    "build-esm": "tsc -b tsconfig.build.json",
    "build-cjs": "babel build/esm --plugins @babel/transform-export-namespace-from --plugins @babel/transform-modules-commonjs --out-dir build/cjs --source-maps",
    "build-annotate": "babel build/esm --plugins annotate-pure-calls --out-dir build/esm --source-maps",
    "check": "tsc -b tsconfig.json",
    "test": "vitest",
    "coverage": "vitest --coverage"
  },
  "peerDependencies": {
    "effect": "*",
    "@effect/experimental": "*"
  },
  "optionalPeerDependencies": {
    "happy-dom": "^15.0.0"
  },
  "devDependencies": {
    "effect": "latest",
    "@effect/experimental": "latest",
    "@effect/vitest": "latest",
    "happy-dom": "^15.0.0"
  }
}
