{
  "$schema": "../../node_modules/@effect/docgen/schema.json",
  "enforceVersion": false,
  "exclude": [
    "src/internal/**/*.ts",
    "src/events/internal/**/*.ts",
    "src/events/IssueComment.ts",
    "src/Comment.ts",
    "src/Issue.ts",
    "src/PR.ts"
  ],
  "examplesCompilerOptions": {
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "module": "ES2022",
    "target": "ES2022",
    "lib": ["ES2022"],
    "paths": {
      "@effect-native/platform-github": ["./src/index.js"],
      "@effect-native/platform-github/*": ["./src/*.js"]
    }
  }
}
