{
  "name": "@effect-native/sql-sqlite-cli",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "A SQLite-CR (CRDT-enabled SQLite) toolkit for Effect",
  "repository": {
    "type": "git",
    "url": "https://github.com/effect-native/effect-native.git",
    "directory": "packages-native/sql-sqlite-cli"
  },
  "bugs": {
    "url": "https://github.com/effect-native/effect-native/issues"
  },
  "tags": [
    "typescript",
    "sql",
    "database",
    "crdt"
  ],
  "keywords": [
    "typescript",
    "sql",
    "database",
    "crdt",
    "crsql",
    "cr-sqlite",
    "sqlite-cr"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "directory": "dist",
    "linkDirectory": false
  },
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./*": "./src/*.ts",
    "./internal/*": null
  },
  "scripts": {
    "codegen": "build-utils prepare-v3",
    "build": "pnpm build-esm && pnpm build-annotate && pnpm build-cjs && build-utils pack-v3",
    "build-esm": "tsc -b tsconfig.build.json",
    "build-cjs": "babel build/esm --plugins @babel/transform-export-namespace-from --plugins @babel/transform-modules-commonjs --out-dir build/cjs --source-maps",
    "build-annotate": "babel build/esm --plugins annotate-pure-calls --out-dir build/esm --source-maps",
    "check": "tsc -b tsconfig.json",
    "test": "vitest",
    "coverage": "vitest --coverage"
  },
  "devDependencies": {
    "@effect/experimental": "workspace:^",
    "@effect/platform": "workspace:^",
    "@effect/platform-node": "workspace:^",
    "@effect/sql": "workspace:^",
    "effect": "workspace:^"
  },
  "peerDependencies": {
    "@effect/experimental": "workspace:^",
    "@effect/platform": "workspace:^",
    "@effect/sql": "workspace:^",
    "effect": "workspace:^"
  },
  "dependencies": {}
}
