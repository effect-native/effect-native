{
  "name": "@effect-native/platform-demo",
  "version": "0.0.1",
  "type": "module",
  "license": "MIT",
  "description": "Portable @effect/platform demonstrations and examples",
  "homepage": "https://github.com/effect-native/effect",
  "repository": {
    "type": "git",
    "url": "https://github.com/effect-native/effect.git",
    "directory": "packages-native/platform-demo"
  },
  "bugs": {
    "url": "https://github.com/effect-native/effect/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "directory": "dist",
    "linkDirectory": false
  },
  "scripts": {
    "codegen": "build-utils prepare-v3",
    "build": "pnpm build-esm && pnpm build-annotate && pnpm build-cjs && build-utils pack-v3",
    "build-esm": "tsc -b tsconfig.build.json",
    "build-cjs": "babel build/esm --plugins @babel/transform-export-namespace-from --plugins @babel/transform-modules-commonjs --out-dir build/cjs --source-maps",
    "build-annotate": "babel build/esm --plugins annotate-pure-calls --out-dir build/esm --source-maps",
    "check": "tsc -b tsconfig.json",
    "circular": "madge --extensions ts --circular --no-color --no-spinner src",
    "test": "vitest",
    "coverage": "vitest --coverage"
  },
  "devDependencies": {
    "@effect/build-utils": "^0.8.3",
    "@effect/platform": "workspace:^",
    "effect": "workspace:^"
  },
  "peerDependencies": {
    "@effect/platform": "workspace:^",
    "effect": "workspace:^"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./*": "./src/*.ts",
    "./internal/*": null
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/dts/index.d.ts",
  "sideEffects": []
}