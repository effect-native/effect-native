#!/usr/bin/env bun
/**
 * Post-commit hook for ssh-keep package
 * Compares SPEC.md to implementation and updates GAPS.md
 */
import { OpenRouter } from "@effect-native/openrouter"
import { Effect, Console } from "effect"
import * as fs from "node:fs/promises"
import * as path from "node:path"

const PACKAGE_DIR = path.resolve(import.meta.dir, "../..")

const readFile = (filePath: string) =>
  Effect.tryPromise({
    try: () => fs.readFile(path.join(PACKAGE_DIR, filePath), "utf-8"),
    catch: () => `[File not found: ${filePath}]`
  })

const writeFile = (filePath: string, content: string) =>
  Effect.tryPromise({
    try: () => fs.writeFile(path.join(PACKAGE_DIR, filePath), content),
    catch: (e) => { throw new Error(`Failed to write ${filePath}: ${e}`) }
  })

const SYSTEM_PROMPT = `You are a technical analyst comparing a specification document to its implementation.

Your task:
1. Identify gaps where the implementation doesn't match the spec
2. Identify where implementation goes beyond what the spec requires (documenting these is informational)
3. Identify potential issues in the implementation (security, correctness, etc.)
4. Prioritize by severity (security > correctness > UX > informational)

Format your response as a structured markdown document with:
- A header "# GAPS.md — Gaps Between Spec and Implementation"
- Clear sections for "Spec Requires, Impl Missing", "Impl Does, Spec Doesn't Specify", and "Potential Issues"
- A summary table with ID, Description, Severity, and whether impl change is needed
- Recommended priority list at the end

Be specific - cite exact spec sections and exact implementation line behaviors.
Do NOT invent issues that don't exist. Be precise and factual.`

const analyzeGaps = Effect.gen(function*() {
  yield* Console.log("ssh-keep: Analyzing spec vs implementation...")
  
  const [spec, impl, index] = yield* Effect.all([
    readFile("SPEC.md"),
    readFile("src/cli.ts"),
    readFile("src/index.ts")
  ])
  
  const openrouter = yield* OpenRouter
  
  const response = yield* openrouter.chat({
    model: "anthropic/claude-sonnet-4",
    messages: [
      { role: "system", content: SYSTEM_PROMPT },
      { 
        role: "user", 
        content: `# Specification
${spec}

# Implementation (src/cli.ts)
${impl}

# Implementation (src/index.ts)
${index}

Analyze the gaps between specification and implementation. Generate a complete GAPS.md document.`
      }
    ]
  })
  
  const gaps = response.choices[0]?.message?.content ?? ""
  
  if (gaps.length < 100) {
    yield* Console.error("ssh-keep: AI response too short, skipping GAPS.md update")
    return
  }
  
  yield* writeFile("GAPS.md", gaps)
  yield* Console.log("ssh-keep: Updated GAPS.md")
})

const main = analyzeGaps.pipe(
  Effect.catchAll((e) => Console.error(`ssh-keep hook error: ${e}`)),
  Effect.provide(OpenRouter.Default)
)

Effect.runPromise(main)
