{
  "extends": "../../tsconfig.base.json",
  "include": [
    "test"
  ],
  "references": [
    {
      "path": "tsconfig.src.json"
    }
  ],
  "compilerOptions": {
    "tsBuildInfoFile": ".tsbuildinfo/test.tsbuildinfo",
    "rootDir": "test",
    "noEmit": true,
    "jsx": "react-jsx",
    "types": [
      "vitest",
      "@testing-library/jest-dom"
    ],
    "paths": {
      "@effect-native/render": [
        "./src/index.ts"
      ],
      "@effect-native/render/*": [
        "./src/*.ts"
      ]
    }
  }
}
