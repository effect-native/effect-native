{
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "ok": "bun run test; TEST=$?; bun run lint; TEST=$(($TEST+$?)); bun run check; TEST=$(($TEST+$?)); bun run circular; TEST=$(($TEST+$?)); bun run codegen; TEST=$(($TEST+$?)); bun run test-types --target current; TEST=$(($TEST+$?)); bun run codemod; TEST=$(($TEST+$?)); bun run build; TEST=$(($TEST+$?)); bun scripts/verify-subpaths.mjs; TEST=$(($TEST+$?)); exit $TEST;",
    "verify-subpaths": "bun scripts/verify-subpaths.mjs",
    "clean": "bun scripts/clean.mjs",
    "codegen": "bun run --filter './packages/*' codegen",
    "codemod": "bun scripts/codemod.mjs && dprint fmt",
    "build": "bun run --filter './packages/*' build",
    "circular": "depcruise --config .dependency-cruiser.cjs \"packages/*/src/**/*.{ts,tsx}\" --output-type err --validate",
    "test": "bun --filter './packages/*' test",
    "coverage": "bun --filter './packages/*' test --coverage",
    "check": "npx tsc -b tsconfig.json",
    "check-recursive": "bun --filter './packages/*' exec tsc -b tsconfig.json",
    "lint": "oxlint && dprint check",
    "lint-fix": "oxlint --fix && dprint fmt",
    "docgen": "bun --filter './packages/*' run docgen && bun scripts/docs.mjs",
    "test-types": "tstyche",
    "changeset-version": "changeset version && bun scripts/force-libsqlite-embedded.mjs",
    "changeset-publish-beta": "bun run codemod && bun run build && bun run test && changeset publish --provenance && bun scripts/postpublish-dist-tags.mjs",
    "changeset-publish": "bun run codemod && bun run build && bun run test && changeset publish --provenance && bun scripts/postpublish-dist-tags.mjs"
  },
  "overrides": {
    "autolinker": "^3.16.2",
    "effect": "beta",
    "dependency-tree": "^10.0.9",
    "detective-amd": "^5.0.2",
    "detective-cjs": "^5.0.1",
    "detective-es6": "^4.0.1",
    "detective-less": "^1.0.2",
    "detective-postcss": "^6.1.3",
    "detective-sass": "^5.0.3",
    "detective-scss": "^4.0.3",
    "detective-stylus": "^4.0.0",
    "detective-typescript": "^11.1.0",
    "jws": "^4.0.1",
    "glob": "^11.0.3",
    "@types/glob": "npm:@types/web@*",
    "@types/minimatch": "npm:@types/web@*",
    "rimraf": "^6.0.1",
    "node-domexception": "npm:noop-package@*"
  },
  "patchedDependencies": {
    "@changesets/assemble-release-plan": "patches/@changesets__assemble-release-plan.patch",
    "ghostty-web@0.3.0": "patches/ghostty-web@0.3.0.patch"
  },
  "trustedDependencies": [
    "better-sqlite3"
  ],
  "devDependencies": {
    "@babel/cli": "^7.28.3",
    "@babel/core": "^7.28.4",
    "@babel/plugin-transform-export-namespace-from": "^7.27.1",
    "@babel/plugin-transform-modules-commonjs": "^7.27.1",
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.7",
    "@edge-runtime/vm": "^5.0.0",
    "@effect/build-utils": "^0.8.9",
    "@effect/docgen": "^0.5.2",
    "@effect/language-service": "^0.23.5",
    "@types/bun": "^1.3.9",
    "@types/jscodeshift": "^17.3.0",
    "@types/node": "^22.19.3",
    "@typescript/native-preview": "^7.0.0-dev",
    "ast-types": "^0.14.2",
    "babel-plugin-annotate-pure-calls": "^0.5.0",
    "dependency-cruiser": "^16.10.4",
    "dprint": "^0.51.1",
    "glob": "^11.0.3",
    "jscodeshift": "^17.3.0",
    "madge": "^8.0.0",
    "oxlint": "^1.42.0",
    "playwright": "^1.55.0",
    "rimraf": "^6.0.1",
    "tstyche": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2"
  }
}
