{
  "name": "Effect Native Windows Development",
  "dockerComposeFile": "docker-compose.yml",
  "service": "dev-windows",
  "workspaceFolder": "C:/workspace",
  
  // Configure the runtime environment
  "remoteUser": "ContainerUser",
  "containerEnv": {
    "NODE_ENV": "development",
    "EFFECT_NATIVE_DEV": "true",
    "EFFECT_NATIVE_LIBSQLITE_DEBUG": "1",
    "PNPM_HOME": "C:/Users/ContainerUser/AppData/Local/pnpm"
  },

  // Forward ports for development servers
  "forwardPorts": [3000, 3001, 4000, 5000, 5173, 5174, 8000, 8080, 9000],
  "portsAttributes": {
    "3000": { "label": "Dev Server", "onAutoForward": "notify" },
    "5173": { "label": "Vite", "onAutoForward": "notify" },
    "8080": { "label": "API", "onAutoForward": "notify" }
  },

  // VS Code customizations for Windows
  "customizations": {
    "vscode": {
      "settings": {
        // Terminal configuration for Windows
        "terminal.integrated.defaultProfile.windows": "PowerShell",
        "terminal.integrated.profiles.windows": {
          "PowerShell": {
            "source": "PowerShell",
            "icon": "terminal-powershell"
          },
          "Command Prompt": {
            "path": [
              "${env:windir}\\Sysnative\\cmd.exe",
              "${env:windir}\\System32\\cmd.exe"
            ],
            "args": [],
            "icon": "terminal-cmd"
          },
          "PowerShell Core": {
            "path": "pwsh.exe",
            "icon": "terminal-powershell"
          }
        },
        
        // Editor settings
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit",
          "source.organizeImports": "never"
        },
        "editor.rulers": [100],
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.detectIndentation": false,
        
        // File settings for Windows
        "files.eol": "\\n",
        "files.insertFinalNewline": true,
        "files.trimTrailingWhitespace": true,
        "files.watcherExclude": {
          "**/node_modules/**": true,
          "**/dist/**": true,
          "**/build/**": true,
          "**/.git/**": true
        },
        
        // TypeScript settings
        "typescript.tsdk": "node_modules/typescript/lib",
        "typescript.enablePromptUseWorkspaceTsdk": true,
        "typescript.preferences.importModuleSpecifier": "relative",
        "typescript.preferences.quoteStyle": "double",
        
        // ESLint settings
        "eslint.validate": [
          "javascript",
          "javascriptreact",
          "typescript",
          "typescriptreact"
        ],
        "eslint.workingDirectories": [
          { "mode": "auto" }
        ],
        
        // Effect settings
        "effect.language-service.enabled": true,
        
        // Git settings
        "git.autofetch": true,
        "git.confirmSync": false,
        "git.enableSmartCommit": true,
        
        // Windows-specific paths
        "search.exclude": {
          "**/node_modules": true,
          "**/dist": true,
          "**/build": true,
          "**/.git": true,
          "**/coverage": true
        },
        
        // Package manager
        "npm.packageManager": "pnpm",
        "debug.javascript.autoAttachFilter": "disabled",
        
        // Windows line endings
        "git.core.autocrlf": false,
        "git.core.eol": "lf"
      },
      
      // VS Code extensions for Windows development
      "extensions": [
        // TypeScript and JavaScript
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-vscode.vscode-typescript-next",
        "effect.effect-vscode",
        
        // Windows development
        "ms-vscode.powershell",
        
        // Database
        "qwtel.sqlite-viewer",
        "alexcvzz.vscode-sqlite",
        
        // Git
        "eamodio.gitlens",
        "mhutchie.git-graph",
        "donjayamanne.githistory",
        
        // Docker
        "ms-azuretools.vscode-docker",
        
        // Development utilities
        "streetsidesoftware.code-spell-checker",
        "wayou.vscode-todo-highlight",
        "gruntfuggly.todo-tree",
        "usernamehw.errorlens",
        "yzhang.markdown-all-in-one",
        "davidanson.vscode-markdownlint",
        
        // Testing
        "vitest.explorer",
        "zixuanchen.vitest-explorer",
        
        // File utilities
        "sleistner.vscode-fileutils",
        "christian-kohler.path-intellisense",
        
        // Themes and icons
        "pkief.material-icon-theme",
        "zhuangtongfa.material-theme",
        
        // Remote development
        "ms-vscode-remote.remote-containers",
        
        // Other
        "editorconfig.editorconfig",
        "mikestead.dotenv",
        "redhat.vscode-yaml"
      ]
    }
  },

  // Features for Windows containers
  "features": {
    // Windows containers have different feature support
  },

  // Commands to run after creating the container
  "postCreateCommand": "powershell -ExecutionPolicy Bypass -File .devcontainer-windows/scripts/post-create.ps1",
  
  // Commands to run after starting the container
  "postStartCommand": "powershell -ExecutionPolicy Bypass -File .devcontainer-windows/scripts/post-start.ps1",
  
  // Commands to run after attaching to the container
  "postAttachCommand": "pnpm install",

  // Mount points for Windows
  "mounts": [
    // Persist pnpm cache
    "source=effect-native-windows-pnpm-store,target=C:/Users/ContainerUser/AppData/Local/pnpm,type=volume",
    // Persist npm cache
    "source=effect-native-windows-npm-cache,target=C:/Users/ContainerUser/AppData/Local/npm-cache,type=volume",
    // PowerShell history
    "source=effect-native-windows-ps-history,target=C:/Users/ContainerUser/AppData/Roaming/Microsoft/Windows/PowerShell/PSReadLine,type=volume"
  ],

  // Container args for Windows
  "runArgs": [
    "--isolation=process"
  ],

  // Update content command
  "updateContentCommand": "pnpm install",

  // Shutdown action
  "shutdownAction": "stopContainer",

  // Host requirements
  "hostRequirements": {
    "cpus": 2,
    "memory": "6gb",
    "storage": "40gb"
  },

  // Windows container specific
  "remoteEnv": {
    "PATH": "${containerEnv:PATH};C:/Users/ContainerUser/AppData/Local/pnpm"
  }
}