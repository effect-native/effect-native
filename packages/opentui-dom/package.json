{
  "name": "@effect-native/opentui-dom",
  "version": "4.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Effect-based DOM adapter interface for unified DOM access across environments.",
  "homepage": "https://github.com/effect-native/effect-native",
  "repository": {
    "type": "git",
    "url": "https://github.com/effect-native/effect-native.git",
    "directory": "packages/opentui-dom"
  },
  "bugs": {
    "url": "https://github.com/effect-native/effect-native/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "directory": "dist",
    "linkDirectory": false
  },
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./*": "./src/*.ts",
    "./bridge/*": "./src/bridge/*.ts",
    "./internal/*": null
  },
  "scripts": {
    "codegen": "echo '@effect-native/opentui-dom: nothing to codegen'",
    "build": "bun run build-esm && bun run build-annotate && bun run build-cjs && build-utils pack-v3",
    "build-esm": "tsc -b tsconfig.build.json",
    "build-cjs": "babel build/esm --plugins @babel/transform-export-namespace-from --plugins @babel/transform-modules-commonjs --out-dir build/cjs --source-maps",
    "build-annotate": "babel build/esm --plugins annotate-pure-calls --out-dir build/esm --source-maps",
    "check": "tsc -b tsconfig.json",
    "test": "bun test",
    "coverage": "bun test --coverage",
    "tui-dom": "bun run poc/miniapp.tsx"
  },
  "peerDependencies": {
    "effect": "^4.0.0-beta.0"
  },
  "devDependencies": {
    "@effect-native/bun-test": "workspace:*",
    "@happy-dom/global-registrator": "^20.0.2",
    "effect": "beta",
    "happy-dom": "^20.0.2",
    "@opentui/core": "^0.1.63",
    "react": "^19",
    "react-dom": "^19",
    "@types/react": "^19",
    "@types/react-dom": "^19"
  }
}
