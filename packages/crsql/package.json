{
  "name": "@effect-native/crsql",
  "version": "4.0.0",
  "type": "module",
  "license": "MIT",
  "description": "CR-SQLite prepared statements and service for Effect SQL",
  "homepage": "https://github.com/effect-native/effect-native/tree/main/packages/crsql",
  "repository": {
    "type": "git",
    "url": "https://github.com/effect-native/effect-native",
    "directory": "packages/crsql"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./*": "./src/*.ts",
    "./internal/*": null
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "directory": "dist",
    "linkDirectory": false
  },
  "scripts": {
    "codegen": "build-utils prepare-v3",
    "build": "bun run build-esm && bun run build-annotate && bun run build-cjs && build-utils pack-v3",
    "build-esm": "tsc -b tsconfig.build.json",
    "build-cjs": "babel build/esm --plugins @babel/transform-export-namespace-from --plugins @babel/transform-modules-commonjs --out-dir build/cjs --source-maps",
    "build-annotate": "babel build/esm --plugins annotate-pure-calls --out-dir build/esm --source-maps",
    "check": "tsc -b tsconfig.json",
    "test": "bun test",
    "coverage": "bun test --coverage"
  },
  "peerDependencies": {
    "effect": "^4.0.0-beta.0"
  },
  "devDependencies": {
    "@effect-native/bun-test": "workspace:*",
    "@effect-native/libcrsql": "workspace:^",
    "@effect/platform-node": "beta",
    "@effect/sql-sqlite-bun": "beta",
    "effect": "beta"
  },
  "dependencies": {
    "@vlcn.io/crsqlite": "^0.16.3"
  },
  "optionalDependencies": {
    "@effect/sql-sqlite-bun": "beta",
    "@effect/sql-sqlite-node": "beta"
  }
}
