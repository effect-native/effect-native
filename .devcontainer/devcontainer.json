{
  "name": "Effect Native Development",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/workspace",
  // Configure the runtime environment
  "remoteUser": "developer",
  "containerEnv": {
    "SHELL": "/bin/zsh",
    "EDITOR": "code --wait",
    "GIT_EDITOR": "code --wait",
    "TERM": "xterm-256color",
    "NODE_ENV": "development",
    "EFFECT_NATIVE_LIBSQLITE_DEBUG": "1"
  },
  // Forward ports for development servers
  "forwardPorts": [
    3000,
    3001,
    4000,
    5000,
    5173,
    5174,
    8000,
    8080,
    9000
  ],
  "portsAttributes": {
    "3000": {
      "label": "Dev Server",
      "onAutoForward": "notify"
    },
    "5173": {
      "label": "Vite",
      "onAutoForward": "notify"
    },
    "8080": {
      "label": "API",
      "onAutoForward": "notify"
    }
  },
  // VS Code customizations
  "customizations": {
    "vscode": {
      "settings": {
        // Terminal configuration
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": {
            "path": "/bin/zsh"
          },
          "bash": {
            "path": "/bin/bash"
          },
          "nix-shell": {
            "path": "/bin/zsh",
            "args": [
              "-c",
              "nix develop"
            ]
          }
        },
        // Editor settings
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit",
          "source.organizeImports": "never"
        },
        "editor.rulers": [
          100
        ],
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.detectIndentation": false,
        // File settings
        "files.eol": "\n",
        "files.insertFinalNewline": true,
        "files.trimTrailingWhitespace": true,
        "files.watcherExclude": {
          "**/node_modules/**": true,
          "**/dist/**": true,
          "**/build/**": true,
          "**/.git/**": true
        },
        // TypeScript settings
        "typescript.tsdk": "node_modules/typescript/lib",
        "typescript.enablePromptUseWorkspaceTsdk": true,
        "typescript.preferences.importModuleSpecifier": "relative",
        "typescript.preferences.quoteStyle": "double",
        // ESLint settings
        "eslint.validate": [
          "javascript",
          "javascriptreact",
          "typescript",
          "typescriptreact"
        ],
        "eslint.workingDirectories": [
          {
            "mode": "auto"
          }
        ],
        // Effect settings
        "effect.language-service.enabled": true,
        // Git settings
        "git.autofetch": true,
        "git.confirmSync": false,
        "git.enableSmartCommit": true,
        // Search settings
        "search.exclude": {
          "**/node_modules": true,
          "**/dist": true,
          "**/build": true,
          "**/.git": true,
          "**/coverage": true,
          "**/.nix-profile": true,
          "**/.nix-defexpr": true
        },
        // Nix settings
        "nix.enableLanguageServer": true,
        "nix.serverPath": "nil",
        // SQLite settings
        "sqlite.logLevel": "DEBUG",
        // Other settings
        "npm.packageManager": "pnpm",
        "debug.javascript.autoAttachFilter": "disabled"
      },
      // VS Code extensions to install
      "extensions": [
        // TypeScript and JavaScript
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-vscode.vscode-typescript-next",
        "effect.effect-vscode",
        // Nix support
        "jnoortheen.nix-ide",
        "arrterian.nix-env-selector",
        // Database
        "qwtel.sqlite-viewer",
        "alexcvzz.vscode-sqlite",
        // Git
        "eamodio.gitlens",
        "mhutchie.git-graph",
        "donjayamanne.githistory",
        // Docker
        "ms-azuretools.vscode-docker",
        // Development utilities
        "streetsidesoftware.code-spell-checker",
        "wayou.vscode-todo-highlight",
        "gruntfuggly.todo-tree",
        "usernamehw.errorlens",
        "yzhang.markdown-all-in-one",
        "davidanson.vscode-markdownlint",
        "bierner.markdown-mermaid",
        // Testing
        "vitest.explorer",
        "zixuanchen.vitest-explorer",
        // File utilities
        "sleistner.vscode-fileutils",
        "christian-kohler.path-intellisense",
        // Themes and icons
        "pkief.material-icon-theme",
        "zhuangtongfa.material-theme",
        // Remote development
        "ms-vscode-remote.remote-containers",
        "ms-vscode-remote.remote-ssh",
        // Other
        "editorconfig.editorconfig",
        "mikestead.dotenv",
        "redhat.vscode-yaml",
        "tamasfe.even-better-toml"
      ]
    }
  },
  // Features to add (these install additional tools)
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "moby": true,
      "dockerDashComposeVersion": "v2"
    },
    "ghcr.io/devcontainers/features/git:1": {
      "version": "latest",
      "ppa": false
    },
    "ghcr.io/devcontainers/features/git-lfs:1": {
      "version": "latest"
    }
  },
  // Commands to run after creating the container
  "postCreateCommand": "nix develop --command bash -lc 'corepack enable pnpm && bash .devcontainer/scripts/post-create.sh'",
  // Commands to run after starting the container
  "postStartCommand": "nix develop --command bash -lc 'corepack enable pnpm || true; bash .devcontainer/scripts/post-start.sh'",
  // Commands to run after attaching to the container
  "postAttachCommand": "nix develop --command bash -lc 'corepack enable pnpm && pnpm install && git config --global --add safe.directory /workspace'",
  // Mount points
  "mounts": [
    // Persist Nix store between rebuilds
    "source=effect-native-nix-store,target=/nix,type=volume",
    // Persist pnpm cache
    "source=effect-native-pnpm-store,target=/home/developer/.pnpm-store,type=volume",
    // Persist shell history
    "source=effect-native-history,target=/commandhistory,type=volume",
    // Share SSH keys from host
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.ssh,target=/home/developer/.ssh,type=bind,readonly",
    // Share Git config from host
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.gitconfig,target=/home/developer/.gitconfig,type=bind,readonly"
  ],
  // Security options
  "runArgs": [
    "--cap-add=SYS_PTRACE",
    "--security-opt",
    "seccomp=unconfined",
    "--network=host"
  ],
  // Update content command
  "updateContentCommand": "nix develop --command bash -lc 'corepack enable pnpm && pnpm install'",
  // Shutdown action
  "shutdownAction": "stopContainer",
  // Host requirements
  "hostRequirements": {
    "cpus": 2,
    "memory": "4gb",
    "storage": "32gb"
  }
}
