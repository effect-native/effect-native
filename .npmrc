# NPM Configuration for effect-native

# Ensure @effect-native packages are public by default
@effect-native:registry=https://registry.npmjs.org/
access=public

# Package provenance for security
provenance=true

# Prevent accidental publication of private packages
# Packages must explicitly set "private": false or use --access public
publish-requires-access=true

# Engine strict mode
engine-strict=true

# Save exact versions in package.json
save-exact=false
